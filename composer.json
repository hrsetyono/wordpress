{
  "name": "pixelstudio/your-site",
  "description": "Run the command `composer init-wp` to install and setup WordPress.",
  "authors": [
    { "name": "Pixel Studio", "email": "info@pixelstudio.id", "homepage": "https://pixelstudio.id" }
  ],
  "require": {
    "pixelstudio/edje-wp-library": "~3.0",
    "pixelstudio/wp-sync-db": "~1.7",
    "wpackagist-plugin/jetpack": "*",
    "wpackagist-plugin/gutenberg": "*",
    "wpackagist-plugin/timber-library": "~1.9.0",
    "wpackagist-plugin/autodescription": "*",
    "wpackagist-plugin/contact-form-7": "*",
    "wpackagist-plugin/w3-total-cache": "*",

    "pixelstudio/edje-wp-theme": "~5.0",
    "wpackagist-theme/twentynineteen": "*"
  },
  "require-dev": {},
  "suggest": {
    "pixelstudio/edje-wc-library": "~2.0",
    "wpackagist-plugin/woocommerce": "*",
    "wpackagist-theme/storefront": "*"
  },
  "scripts": {
    "init-wp": [
      "composer update",
      "wp core download --skip-content",
      "wp config create",
      "wp db create",
      "wp core install"
    ],
    "live-init": [
      "wp @live $(composer init-wp) cli version"
    ],
    "live-update": [
      "wp @live $(composer update) cli version"
    ],
  },
  "repositories": [
    { "type": "composer", "url":"https://wpackagist.org" }
  ],
  "autoload": { "psr-0": { "Acme": "src/" } }
}